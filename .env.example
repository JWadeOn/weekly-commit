# Database (local dev: postgres user, password below)
DB_URL=jdbc:postgresql://localhost:5433/weeklycommit
DB_USERNAME=postgres
DB_PASSWORD=postgres

# OAuth2 — local dev (mock server on 8090). For Docker, see docker-compose.yml.
OAUTH_CLIENT_ID=weekly-commit-client
OAUTH_CLIENT_SECRET=client-secret
OAUTH_ISSUER_URI=http://localhost:8090
OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/oidc

# JWT (internal token issued after OAuth exchange)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY_HOURS=24

# Module Federation — browser-facing URL of the remote MFE
REMOTE_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Production (e.g. Auth0) — set these on the backend service (Railway, etc.)
# See docs/DEPLOYMENT.md "Implementation plan: Production OAuth (Auth0)"
# -----------------------------------------------------------------------------
# OAUTH_ISSUER_URI=https://YOUR_TENANT.auth0.com/
# OAUTH_CLIENT_ID=<from Auth0 Application>
# OAUTH_CLIENT_SECRET=<from Auth0 Application>
# OAUTH_REDIRECT_URI=https://YOUR_BACKEND_HOST/login/oauth2/code/oidc
# OAUTH_AUTHORIZATION_URI=https://YOUR_TENANT.auth0.com/authorize
# OAUTH_JWK_SET_URI=https://YOUR_TENANT.auth0.com/.well-known/jwks.json
# JWT_SECRET=<long-random-secret>
# FRONTEND_URL=https://YOUR_HOST_APP_URL
# CORS_ALLOWED_ORIGINS=https://YOUR_HOST_APP_URL
