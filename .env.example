# Database
DB_URL=jdbc:postgresql://localhost:5432/weeklycommit
DB_USERNAME=weeklycommit
DB_PASSWORD=weeklycommit_secret

# OAuth2 (mock-oauth2-server for local dev)
OAUTH_CLIENT_ID=mock-client
OAUTH_CLIENT_SECRET=mock-secret
OAUTH_ISSUER_URI=http://localhost:8090
OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback

# JWT (internal token issued after OAuth exchange)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRY_HOURS=24

# Module Federation — browser-facing URL of the remote MFE
REMOTE_URL=http://localhost:3001
